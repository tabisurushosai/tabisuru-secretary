# Vercel + Upstash Marketplace で自動注入される (本番)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel ダッシュボード手動設定
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# Mac 秘書 → Vercel /api/heartbeat 用 (任意)
HB_SHARED_TOKEN=

# Gmail App Password (GitHub Actions secrets にも同じ値を入れる)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Chrome Web Store API (GitHub Actions 用、credentials.json の中身を JSON 文字列で)
CWS_CREDENTIALS_JSON=

# Chrome 拡張の item_id マッピング (GitHub Actions 用)
# 例: {"parent-news":"abc...","toikake":"def..."}
CWS_ITEM_IDS_JSON=
